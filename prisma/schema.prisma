generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  tcallId         String?  @unique
  email           String   @unique
  name            String
  password        String
  language        String   @default("uz")
  translationMode String   @default("text")
  status          String   @default("available")
  bio             String?
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hostedCalls       Call[]            @relation("HostCalls")
  callLogs          CallParticipant[]
  vanityNumber      VanityNumber?
  vanityRequests    VanityNumberRequest[]
  contacts          Contact[]         @relation("OwnerContacts")
  blocks            BlockedUser[]     @relation("Blocker")
  quickMessagesSent QuickMessage[]    @relation("MessageSender")
}

model Contact {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("OwnerContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  tcallId   String
  favorite  Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, tcallId])
  @@index([ownerId])
}

model BlockedUser {
  id             String   @id @default(cuid())
  blockerId      String
  blocker        User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedTcallId String
  createdAt      DateTime @default(now())

  @@unique([blockerId, blockedTcallId])
}

model VanityNumber {
  id          String    @id @default(cuid())
  number      String    @unique
  price       Int
  tier        String    @default("gold")
  available   Boolean   @default(true)
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])
  purchasedAt DateTime?
  createdAt   DateTime  @default(now())

  requests VanityNumberRequest[]
}

model VanityNumberRequest {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  number         String
  price          Int
  tier           String
  status         String        @default("pending")
  vanityNumberId String?
  vanityNumber   VanityNumber? @relation(fields: [vanityNumberId], references: [id], onDelete: SetNull)
  note           String?
  createdAt      DateTime      @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?

  @@index([userId])
  @@index([status])
  @@index([number])
}

model Call {
  id                String    @id @default(cuid())
  roomId            String    @unique
  hostId            String
  host              User      @relation("HostCalls", fields: [hostId], references: [id])
  calleeTcallId     String?
  callType          String    @default("room")
  status            String    @default("waiting")
  durationSec       Int?
  transcriptSummary String?
  createdAt         DateTime  @default(now())
  endedAt           DateTime?

  participants CallParticipant[]
  transcripts  CallTranscript[]

  @@index([hostId])
  @@index([status])
  @@index([createdAt])
  @@index([calleeTcallId])
}

model CallParticipant {
  id       String    @id @default(cuid())
  callId   String
  call     Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([callId, userId])
}

model CallTranscript {
  id             String   @id @default(cuid())
  callId         String
  call           Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  speakerName    String
  originalText   String
  translatedText String?
  sourceLang     String
  targetLang     String?
  createdAt      DateTime @default(now())

  @@index([callId])
}

model QuickMessage {
  id               String   @id @default(cuid())
  senderId         String
  sender           User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientTcallId String
  message          String
  read             Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([recipientTcallId])
  @@index([senderId])
}
