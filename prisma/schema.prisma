generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  tcallId         String?  @unique
  email           String   @unique
  name            String
  password        String
  language        String   @default("uz")
  translationMode String   @default("text")
  status          String   @default("available")
  bio             String?
  avatar          String?
  age             Int?
  city            String?
  country         String?
  address         String?
  workplace       String?
  education       String?
  graduatedFrom   String?
  profession      String?
  interests       String?
  skills          String?
  about           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime?

  hostedCalls       Call[]            @relation("HostCalls")
  callLogs          CallParticipant[]
  vanityNumber      VanityNumber?
  vanityRequests    VanityNumberRequest[]
  contacts          Contact[]         @relation("OwnerContacts")
  blocks            BlockedUser[]     @relation("Blocker")
  messageReactions  MessageReaction[]
  unblockRequestsSent     UnblockRequest[] @relation("UnblockRequestsSent")
  unblockRequestsReceived UnblockRequest[] @relation("UnblockRequestsReceived")
  friendRequestsSent     FriendRequest[] @relation("FriendRequestsSent")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestsReceived")
  subscription           Subscription?
  bans                   UserBan[]
  quickMessagesSent QuickMessage[]    @relation("MessageSender")
  conversationsCreated Conversation[] @relation("ConversationCreator")
  conversationMembers  ConversationMember[]
  chatMessagesSent     ChatMessage[]  @relation("ChatMessageSender")
  deviceTokens         DeviceToken[]
  passwordResetTokens  PasswordResetToken[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("Admin")
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      String   @default("free")
  status    String   @default("active")
  startedAt DateTime @default(now())
  expiresAt DateTime?
  price     Float    @default(0)
  note      String?
  grantedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan, status])
  @@index([expiresAt])
}

model UserBan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  bannedBy  String
  expiresAt DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, active])
}

model ContentReport {
  id         String   @id @default(cuid())
  type       String
  targetId   String
  reason     String
  notes      String?
  reportedBy String?
  status     String   @default("pending")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("OwnerContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  tcallId   String
  favorite  Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, tcallId])
  @@index([ownerId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("FriendRequestsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("FriendRequestsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model BlockedUser {
  id             String   @id @default(cuid())
  blockerId      String
  blocker        User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedTcallId String
  createdAt      DateTime @default(now())

  @@unique([blockerId, blockedTcallId])
}

model UnblockRequest {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("UnblockRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  blockerId   String
  blocker     User     @relation("UnblockRequestsReceived", fields: [blockerId], references: [id], onDelete: Cascade)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@unique([requesterId, blockerId])
  @@index([blockerId, status])
}

model VanityNumber {
  id          String    @id @default(cuid())
  number      String    @unique
  price       Int
  tier        String    @default("gold")
  available   Boolean   @default(true)
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])
  purchasedAt DateTime?
  createdAt   DateTime  @default(now())

  requests VanityNumberRequest[]
}

model VanityNumberRequest {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  number         String
  price          Int
  tier           String
  status         String        @default("pending")
  vanityNumberId String?
  vanityNumber   VanityNumber? @relation(fields: [vanityNumberId], references: [id], onDelete: SetNull)
  note           String?
  createdAt      DateTime      @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?

  @@index([userId])
  @@index([status])
  @@index([number])
}

model Call {
  id                String    @id @default(cuid())
  roomId            String    @unique
  hostId            String
  host              User      @relation("HostCalls", fields: [hostId], references: [id])
  calleeTcallId     String?
  callType          String    @default("room")
  status            String    @default("waiting")
  durationSec       Int?
  transcriptSummary String?
  createdAt         DateTime  @default(now())
  endedAt           DateTime?

  participants CallParticipant[]
  transcripts  CallTranscript[]

  @@index([hostId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([calleeTcallId])
  @@index([hostId, status])
}

model CallParticipant {
  id       String    @id @default(cuid())
  callId   String
  call     Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([callId, userId])
}

model CallTranscript {
  id             String   @id @default(cuid())
  callId         String
  call           Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  speakerName    String
  originalText   String
  translatedText String?
  sourceLang     String
  targetLang     String?
  createdAt      DateTime @default(now())

  @@index([callId])
}

model QuickMessage {
  id               String   @id @default(cuid())
  senderId         String
  sender           User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientTcallId String
  message          String
  read             Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([recipientTcallId])
  @@index([senderId])
}

model Conversation {
  id          String   @id @default(cuid())
  type        String   @default("direct")
  name        String?
  avatar      String?
  directKey   String?  @unique
  createdById String
  createdBy   User     @relation("ConversationCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ConversationMember[]
  messages ChatMessage[]

  @@index([updatedAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  hiddenAt       DateTime?
  pinnedAt       DateTime?
  mutedUntil     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([userId, pinnedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("ChatMessageSender", fields: [senderId], references: [id])
  type           String       @default("text")
  originalText   String?
  sourceLang     String?
  mediaUrl       String?
  mediaMime      String?
  mediaName      String?
  mediaSize      Int?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  replyToId      String?
  replyTo        ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        ChatMessage[] @relation("MessageReplies")

  translations MessageTranslation[]
  reactions    MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageTranslation {
  id         String      @id @default(cuid())
  messageId  String
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  targetLang String
  text       String

  @@unique([messageId, targetLang])
  @@index([messageId])
}
