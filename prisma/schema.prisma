generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  tcallId         String?  @unique
  email           String   @unique
  name            String
  password        String
  language        String   @default("uz")
  translationMode String   @default("text")
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hostedCalls  Call[]            @relation("HostCalls")
  callLogs     CallParticipant[]
  vanityNumber VanityNumber?
}

model VanityNumber {
  id          String    @id @default(cuid())
  number      String    @unique
  price       Int
  tier        String    @default("gold")
  available   Boolean   @default(true)
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])
  purchasedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Call {
  id           String    @id @default(cuid())
  roomId       String    @unique
  hostId       String
  host         User      @relation("HostCalls", fields: [hostId], references: [id])
  calleeTcallId String?
  status       String    @default("waiting")
  createdAt    DateTime  @default(now())
  endedAt      DateTime?

  participants CallParticipant[]
}

model CallParticipant {
  id       String    @id @default(cuid())
  callId   String
  call     Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([callId, userId])
}
