# Production environment — serverda /var/www/tcall/.env ga nusxalang
NODE_ENV=production
PORT=3010
HOSTNAME=0.0.0.0

DATABASE_URL="file:./prod.db"
JWT_SECRET=CHANGE-THIS-TO-RANDOM-64-CHAR-STRING

NEXT_PUBLIC_LANDING_URL=https://tcall.uz
NEXT_PUBLIC_WEB_APP_URL=https://web.tcall.uz
NEXT_PUBLIC_APP_URL=https://web.tcall.uz
NEXT_PUBLIC_API_URL=https://api.tcall.uz
COOKIE_DOMAIN=.tcall.uz

OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_VOICE=nova

# Admin panel — vergul bilan ajratilgan email lar
ADMIN_EMAILS=admin@example.com

# Parol tiklash email (Resend.com)
RESEND_API_KEY=
MAIL_FROM=Tcall <noreply@tcall.uz>

# Cryptomus — kripto to'lov (obuna)
MERCHANT_ID=dd45d28b-8290-4c02-b020-44de35baf2d0
PAYMENT_API_KEY=your-payment-api-key-from-cryptomus-dashboard
PREMIUM_PRICE_UZS=60000
PREMIUM_PLUS_PRICE_UZS=120000
PAYMENT_WINDOW_MIN=60

# Firebase Cloud Messaging (server → telefon push)
# Firebase Console → tcall-28118 → Service accounts → Generate new private key
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"tcall-28118",...}
