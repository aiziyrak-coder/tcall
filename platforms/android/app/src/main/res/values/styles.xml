<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="tcall_blue">#007AFF</color>
    <color name="tcall_bg">#F2F2F7</color>

    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/tcall_bg</item>
        <item name="android:navigationBarColor">@color/tcall_bg</item>
        <item name="android:windowBackground">@color/tcall_bg</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/tcall_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
</resources>
